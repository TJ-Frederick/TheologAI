# ESV API Configuration (get from https://api.esv.org/)
ESV_API_KEY=your_esv_api_key_here

# NET Bible API (optional)
NET_BIBLE_API_KEY=optional_net_bible_key

# Cache Configuration
CACHE_TTL=3600000
MAX_CACHE_SIZE=1000

# Logging
LOG_LEVEL=info

# HTTP server configuration (optional; leave PORT unset for stdio mode)
# PORT=3000
# HOST=127.0.0.1
# MCP_ALLOWED_HOSTS=localhost,127.0.0.1
# MCP_ALLOWED_ORIGINS=http://localhost:5173
# MCP_MAX_BODY_BYTES=1048576
