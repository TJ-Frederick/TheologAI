{
  "name": "theologai",
  "version": "3.6.0",
  "private": true,
  "description": "A Model Context Protocol server for Bible study and theological research",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/data && cp src/data/parallel-passages.json src/data/ubs-parallel-passages.generated.json dist/data/",
    "build:ubs-parallel-passages": "tsx scripts/build-ubs-parallel-passages.ts",
    "build:strongs": "tsx scripts/build-strongs-json.ts",
    "build:stepbible": "tsx scripts/build-stepbible-json.ts",
    "build:stepbible:lexicons": "tsx scripts/build-stepbible-lexicons.ts",
    "build:db": "tsx scripts/build-database.ts",
    "data:verify-sources": "tsx scripts/verify-data-manifest.ts",
    "data:verify-section-keys": "tsx scripts/historical-section-key-plan.ts",
    "data:verify-language-sources": "tsx scripts/verify-biblical-language-sources.ts",
    "data:verify-ubs-hebrew-coordinate-audit": "tsx scripts/reproduce-ubs-hebrew-v092-coordinate-audit.ts",
    "data:build-ubs-hebrew-coordinate-bridge": "tsx scripts/build-ubs-hebrew-v092-coordinate-bridge.ts --write",
    "data:verify-ubs-hebrew-coordinate-bridge": "tsx scripts/build-ubs-hebrew-v092-coordinate-bridge.ts",
    "data:build-ubs-hebrew-semantic-compilation-audit": "tsx scripts/verify-ubs-hebrew-v092-semantic-compilation.ts --write-audit",
    "data:verify-ubs-hebrew-semantic-compilation": "tsx scripts/verify-ubs-hebrew-v092-semantic-compilation.ts",
    "data:reproduce-language-sources": "tsx scripts/reproduce-biblical-language-sources.ts",
    "data:verify-language-reproduction-report": "tsx scripts/verify-biblical-language-reproduction-report.ts",
    "data:write-language-source-lock": "tsx scripts/write-biblical-language-source-lock.ts",
    "data:finalize-language-unicode-manifest": "tsx scripts/finalize-biblical-language-unicode-manifest.ts",
    "data:verify-db": "tsx scripts/verify-database.ts",
    "d1:seed:export": "tsx scripts/export-for-d1.ts",
    "d1:seed:verify": "tsx scripts/verify-d1-seed.ts",
    "d1:seed:verify-import": "tsx scripts/verify-d1-seed-import.ts",
    "d1:seed:verify-workerd": "tsx scripts/verify-d1-seed-workerd.ts",
    "d1:corpus:compare": "tsx scripts/compare-d1-corpora.ts",
    "d1:remote:check": "tsx scripts/check-remote-d1-readiness.ts",
    "benchmark:ubs-runtime": "node --expose-gc --import tsx scripts/benchmark-ubs-runtime.ts",
    "audit:parallel-preview": "tsx scripts/audit-parallel-passages-preview.ts",
    "audit:ccel-preview": "tsx scripts/audit-ccel-preview.ts",
    "test:worker-bundle-ubs": "tsx scripts/check-worker-bundle-excludes-ubs.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "npm run typecheck:node && npm run typecheck:worker",
    "typecheck:node": "tsc --noEmit -p tsconfig.json",
    "typecheck:worker": "tsc --noEmit -p tsconfig.worker.json",
    "typecheck:ccel-coordinator": "tsc --noEmit -p tsconfig.ccel-coordinator.json",
    "typecheck:ccel-coordinator-test": "tsc --noEmit -p tsconfig.ccel-coordinator-test.json",
    "typecheck:worker-runtime": "tsc --noEmit -p test/worker-runtime/tsconfig.json",
    "typecheck:test-fixtures": "tsc --noEmit -p tsconfig.test-fixtures.json",
    "types:worker": "WRANGLER_LOG_PATH=test-output/wrangler/logs wrangler types worker-configuration.d.ts --config wrangler.toml --env-file /dev/null",
    "types:worker:check": "WRANGLER_LOG_PATH=test-output/wrangler/logs wrangler types worker-configuration.d.ts --config wrangler.toml --env-file /dev/null --check",
    "types:ccel-coordinator": "WRANGLER_LOG_PATH=test-output/wrangler/logs wrangler types ccel-coordinator-configuration.d.ts --config wrangler.ccel-coordinator.toml --env-file /dev/null --include-runtime false",
    "types:ccel-coordinator:check": "WRANGLER_LOG_PATH=test-output/wrangler/logs wrangler types ccel-coordinator-configuration.d.ts --config wrangler.ccel-coordinator.toml --env-file /dev/null --include-runtime false --check",
    "validate:worker-config": "WRANGLER_LOG_PATH=test-output/wrangler/logs wrangler deploy --dry-run --env= --outdir test-output/wrangler/production && WRANGLER_LOG_PATH=test-output/wrangler/logs wrangler deploy --dry-run --env preview --outdir test-output/wrangler/preview",
    "validate:release-config": "WRANGLER_LOG_PATH=test-output/wrangler/logs wrangler deploy --dry-run --config wrangler.release.toml --outdir test-output/wrangler/release",
    "validate:ccel-coordinator-config": "WRANGLER_LOG_PATH=test-output/wrangler/logs wrangler deploy --dry-run --config wrangler.ccel-coordinator.toml --outdir test-output/wrangler/ccel-coordinator",
    "validate:ccel-coordinator-test-config": "WRANGLER_LOG_PATH=test-output/wrangler/logs wrangler deploy --dry-run --config test/ccel-coordinator-runtime/wrangler.test.toml --outdir test-output/wrangler/ccel-coordinator-test",
    "test": "npm run test:unit && npm run test:integration",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run test/unit",
    "test:d1-readiness-generated-db": "vitest run test/unit/scripts/checkRemoteD1Readiness.test.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:conformance": "tsx test/conformance/run-server-conformance.ts",
    "test:worker-runtime": "vitest run --config vitest.worker.config.ts",
    "test:ccel-coordinator-runtime": "vitest run --config vitest.ccel-coordinator.config.ts",
    "test:worker-production-runtime": "tsx scripts/test-worker-production-runtime.ts",
    "test:data": "tsx scripts/test-data-pipeline.ts",
    "docs:check": "vitest run test/unit/docs/publicContract.test.ts",
    "test:all": "npm run test:coverage && npm run test:integration && npm run test:worker-runtime && npm run test:worker-production-runtime && npm run test:e2e && npm run test:conformance && npm run test:data && npm run d1:seed:verify-workerd",
    "test:e2e": "npm run build && npm run test:e2e:compiled",
    "test:e2e:compiled": "tsx scripts/test-node-http-e2e.ts",
    "test:coverage": "vitest run --coverage",
    "test:ccel": "vitest run test/unit/adapters/commentary/CcelSearchAdapter.test.ts test/unit/services/historical/CcelUpstreamCoordinator.test.ts test/unit/presenters/primarySourceSearchV4Structured.test.ts test/unit/http/worker/ccelOperator.test.ts test/unit/scripts/ccelCoordinatorOperator.test.ts",
    "test:netbible": "tsx test/adapters/netbible-test.ts",
    "test:bibleapi": "tsx test/adapters/bibleapi-test.ts",
    "test:commentary": "tsx test/integration/public-commentary-test.ts",
    "test:all-books": "tsx test/integration/all-books-mapping-test.ts",
    "test:helloao-bible": "tsx test/adapters/helloao-bible-test.ts"
  },
  "keywords": [
    "bible",
    "theology",
    "mcp",
    "context-protocol"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22.18.0 <23"
  },
  "overrides": {
    "@cloudflare/vitest-pool-workers": {
      "wrangler": "4.107.0"
    },
    "@modelcontextprotocol/sdk": {
      "@hono/node-server": "2.0.11"
    }
  },
  "dependencies": {
    "@cfworker/json-schema": "4.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "agents": "0.17.3",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "parse5": "8.0.1",
    "typescript": "^5.9.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260702.1",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@modelcontextprotocol/conformance": "0.1.16",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.5.2",
    "@types/xml2js": "^0.4.14",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "ajv": "8.20.0",
    "happy-dom": "^20.0.4",
    "miniflare": "4.20260708.1",
    "nodemon": "^3.1.10",
    "smol-toml": "^1.6.1",
    "tsx": "^4.20.6",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.107.0",
    "xml2js": "^0.6.2"
  }
}
