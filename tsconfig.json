{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/worker.ts",
    "src/ccel-coordinator-worker.ts",
    "src/worker-server.ts",
    "src/worker-env.ts",
    "src/http/worker",
    "src/adapters/d1",
    "src/tools/worker",
    "src/shims"
  ]
}
