                ]
              },
              {
                "allOf": [
                  { "$ref": "#/$defs/sourceProvenance" },
                  {
                    "type": "object",
                    "properties": {
                      "sourceRole": { "const": "lexical_domains" },
                      "artifactName": { "const": "UBSHebrewDicLexicalDomains-v0.9.2-en.JSON" }
                    },
                    "required": ["sourceRole", "artifactName"]
                  }
                ]
              }
            ],
            "items": false
          },
          "transformation": {
            "type": "object",
            "properties": {
              "schemaVersion": { "const": "ubs-semantics.v1" },
              "transformVersion": { "const": 7 },
              "artifactIdentity": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            },
            "required": ["schemaVersion", "transformVersion", "artifactIdentity"],
            "additionalProperties": false
          }
        },
        "required": ["sources", "transformation"],
        "additionalProperties": false
      }
    }
