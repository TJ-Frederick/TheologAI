{
  "schemaVersion": "4",
  "tool": "parallel_passages",
  "cases": [
    {
      "name": "hard default is UBS only",
      "arguments": { "reference": "Luke 6:35" },
      "assert": ["success", "ubsGroupsPresent"]
    },
    {
      "name": "default bounded result observes an additional UBS group",
      "arguments": { "reference": "Mark 10:19" },
      "assert": ["success", "v4AdditionalDefaultWindow", "v4SemanticsValid"]
    },
    {
      "name": "opaque continuation returns the remaining UBS groups only",
      "cursorFrom": "default bounded result observes an additional UBS group",
      "arguments": { "reference": "Mark 10:19", "maxGroups": 5 },
      "assert": ["success", "ubsGroupsPresent", "terminalCursorAbsent", "v4SemanticsValid"]
    },
    {
      "name": "malformed opaque cursor is an invalid parameter",
      "cursorFrom": "default bounded result observes an additional UBS group",
      "cursorMutation": "malformed",
      "arguments": { "reference": "Mark 10:19", "maxGroups": 5 },
      "assert": ["toolError", "invalidCursorParameter"]
    },
    {
      "name": "canonical false-terminal cursor is an invalid parameter",
      "cursorFrom": "default bounded result observes an additional UBS group",
      "cursorMutation": "false_terminal",
      "arguments": { "reference": "Mark 10:19", "maxGroups": 5 },
      "assert": ["toolError", "invalidCursorParameter"]
    },
    {
      "name": "opaque cursor cannot be replayed against another passage",
      "cursorFrom": "default bounded result observes an additional UBS group",
      "arguments": { "reference": "Matthew 5:44" },
      "assert": ["toolError", "cursorQueryMessage"]
    },
    {
      "name": "opaque cursor rejects an explicit OpenBible control",
      "cursorFrom": "default bounded result observes an additional UBS group",
      "arguments": { "reference": "Mark 10:19", "includeOpenBibleCrossReferences": false },
      "assert": ["toolError"]
    },
    {
      "name": "opaque cursor rejects text enrichment",
      "cursorFrom": "default bounded result observes an additional UBS group",
      "arguments": { "reference": "Mark 10:19", "maxGroups": 5, "includeText": true },
      "assert": ["toolError"]
    },
    {
      "name": "reviewed maximum returns seven observed groups without an extra match",
      "arguments": { "reference": "Mark 10:19", "maxGroups": 10 },
      "assert": ["success", "v4MaximumObservedWindow", "v4SemanticsValid"]
    },
    {
      "name": "v4 text enrichment enforces the 12-target budget without losing metadata",
      "arguments": { "reference": "Mark 10:19", "maxGroups": 10, "includeText": true, "translation": "WEB" },
      "assert": ["success", "v4MaximumObservedWindow", "v4TextBudgetApplied", "textBudgetPreservesMetadataAndStatuses", "excerptsBounded"]
    },
    {
      "name": "Kings Chronicles and Isaiah remain one complete source group",
      "arguments": { "reference": "2 Kings 18:13" },
      "assert": ["success", "completeKingsChroniclesIsaiahGroup"]
    },
    {
      "name": "Matthew locator preserves distinct source groups",
      "arguments": { "reference": "Matthew 3:3" },
      "assert": ["success", "distinctMatthewGroups"]
    },
    {
      "name": "alignment is explicit",
      "arguments": { "reference": "Luke 6:35", "includeAlignment": true, "maxGroups": 1 },
      "assert": ["success", "ubsGroupsPresent", "alignmentPresent"]
    },
    {
      "name": "all group members receive text",
      "arguments": { "reference": "Luke 6:35", "includeText": true, "translation": "WEB", "maxGroups": 1 },
      "assert": ["success", "ubsGroupsPresent", "memberTextPresent", "textAttributionPresent", "excerptsBounded"]
    },
    {
      "name": "legacy remains explicit and unchanged",
      "arguments": { "reference": "Matthew 26:26", "corpora": ["theologai_legacy"], "mode": "synoptic", "maxParallels": 2 },
      "assert": ["success", "legacyParallelsPresent", "ubsNotEvaluated"]
    },
    {
      "name": "both corpora remain separated",
      "arguments": { "reference": "Matthew 26:26", "corpora": ["ubs_source_attested", "theologai_legacy"], "mode": "auto", "maxGroups": 2 },
      "assert": ["success", "bothCorpora", "ubsGroupsPresent", "legacyParallelsPresent"]
    },
    {
      "name": "OpenBible is separate and opt in",
      "arguments": { "reference": "John 3:16", "includeOpenBibleCrossReferences": true },
      "assert": ["success", "openBibleSeparate", "openBibleAttribution"]
    },
    {
      "name": "deprecated alias conflict is rejected",
      "arguments": { "reference": "John 3:16", "includeOpenBibleCrossReferences": true, "useCrossReferences": false },
      "assert": ["toolError", "conflictMessage"]
    },
    {
      "name": "legacy controls do not infer legacy",
      "arguments": { "reference": "Matthew 26:26", "mode": "synoptic" },
      "assert": ["toolError", "explicitLegacyInstruction"]
    },
    {
      "name": "valid no-result query remains successful",
      "arguments": { "reference": "Psalms 119:176" },
      "assert": ["success", "noUbsGroups"]
    },
    {
      "name": "fully default-populated client arguments are accepted",
      "arguments": {
        "reference": "Luke 6:35",
        "corpora": ["ubs_source_attested"],
        "includeText": false,
        "translation": "ESV",
        "maxGroups": 5,
        "includeAlignment": false,
        "includeOpenBibleCrossReferences": false
      },
      "assert": ["success", "defaultsAccepted", "ubsGroupsPresent"]
    },
    {
      "name": "removed legacy defaults are not tolerated as UBS controls",
      "arguments": {
        "reference": "Luke 6:35",
        "corpora": ["ubs_source_attested"],
        "mode": "auto",
        "maxParallels": 10,
        "useCrossReferences": false
      },
      "assert": ["toolError", "explicitLegacyInstruction"]
    }
  ]
}
